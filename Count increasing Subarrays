class Solution {
    public int countIncreasing(int[] arr) {
        int n = arr.length;
        int len = 1;
        int result = 0;

        for (int i = 1; i < n; i++) {
            if (arr[i] > arr[i - 1]) {
                len++;
            } else {
                result += (len * (len - 1)) / 2;
                len = 1;
            }
        }
        result += (len * (len - 1)) / 2;

        return result;
    }
}
